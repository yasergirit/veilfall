{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:shared && npm run build:client",
  "outputDirectory": "packages/client/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
