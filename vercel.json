{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../shared && npx tsc -p tsconfig.json && cd ../client && npx vite build",
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
